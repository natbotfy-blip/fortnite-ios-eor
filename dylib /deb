#!/bin/bash
# EditOnRelease_iOS_Fortnite_Tweak_Builder.sh
# One-click builder for .deb + .dylib for KSign injection
# Requires: Mac with Xcode CLI tools, Theos installed
# Run: bash this_script.sh

set -e  # Exit on error

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo -e "${GREEN}=== Edit on Release Tweak Builder for iOS Fortnite (KSign Ready) ===${NC}"
echo "Forces auto-confirm edits on release for private projects (Era/Flux/OG)."
echo ""

# Step 1: Install Theos if missing
if [ ! -d "$HOME/theos" ]; then
    echo -e "${YELLOW}Installing Theos...${NC}"
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/theos/theos/master/bin/install-theos)"
    echo 'export THEOS=$HOME/theos' >> ~/.zshrc
    source ~/.zshrc
fi
export THEOS=$HOME/theos

# Step 2: Create project dir
PROJECT_DIR="$HOME/EditOnRelease"
rm -rf "$PROJECT_DIR"
mkdir -p "$PROJECT_DIR"
cd "$PROJECT_DIR"

echo -e "${YELLOW}Creating Theos project...${NC}"
$THEOS/bin/nic.pl << 'EOF'
11
1
EditOnRelease
com.epicgames.fortnite
y
EOF

# Step 3: Write Tweak.xm (optimized hooks for Fortnite UE4/5 private IPAs)
cat > Tweak.xm << 'EOF'
#import <substrate.h>

%hook UFortEditTool

- (void)OnStopEdit {
    [self ConfirmEdit];
    %orig;
}

- (void)StopEditing {
    [self ConfirmEdit];
    %orig;
}

%end

%hook UFortInputComponentPlayer

- (void)InputTouchEndEdit {
    id editTool = [self GetEditTool];
    if (editTool) [editTool ConfirmEdit];
    %orig;
}

%end

// Fallback: Generic touch release in edit mode
%hook UMGFrontendHUD

- (void)HandleTouchInput:(UITouch *)touch {
    if ([touch phase] == UITouchPhaseEnded) {
        // Detect edit context via shared player controller
        id pc = [%c(UFortPlayerController) localPlayerController];
        if ([[pc CurrentTool] isKindOfClass:%c(UFortEditTool)]) {
            [[pc CurrentTool] ConfirmEdit];
        }
    }
    %orig(touch);
}

%end

%ctor {
    %init;
    NSLog(@"[EditOnRelease] ✅ Loaded - Auto Confirm Edits FORCED ON!");
}
EOF

# Step 4: Write control file
cat > control << 'EOF'
Package: com.nat.editonrelease
Name: Edit on Release (Fortnite iOS)
Version: 1.0
Architecture: iphoneos-arm64
Description: Forces Confirm Edit on Release for Fortnite private servers/IPAs.
Depends: mobilesubstrate (>= 0.9.5000), firmware (>= 13.0)
Maintainer: Nat <nat@austin.tx>
Author: Grok-built Tweak
Section: Tweaks
EOF

# Step 5: Write Makefile
cat > Makefile << 'EOF'
include $(THEOS)/makefiles/common.mk

ARCHS = arm64 arm64e
TARGET := iphone:clang:latest:17.0
THEOS_DEVICE_IP = 127.0.0.1  # For KSign/sideload only

TWEAK_NAME = EditOnRelease
EditOnRelease_FILES = Tweak.xm
EditOnRelease_CFLAGS = -fobjc-arc
EditOnRelease_CCFLAGS = -std=c++17
EditOnRelease_FRAMEWORKS = UIKit Foundation GameplayKit
EditOnRelease_LIBRARIES = substrate

include $(THEOS_MAKE_PATH)/tweak.mk
include $(THEOS_MAKE_PATH)/aggregate.mk
EOF

# Step 6: Build
echo -e "${YELLOW}Building .deb + .dylib... (2-5 mins)${NC}"
make clean && make package FINALPACKAGE=1

# Step 7: Output files
DEB_FILE="packages/EditOnRelease_1.0_iphoneos-arm64.deb"
DYLIB_FILE="EditOnRelease.dylib"  # Extract if needed: dpkg-deb -x *.deb extracted/ ; find extracted/ -name "*.dylib"

if [ -f "$DEB_FILE" ]; then
    echo -e "${GREEN}✅ SUCCESS! Files ready:${NC}"
    echo "  .deb: $(pwd)/$DEB_FILE  ← Import to KSign as Tweak"
    echo "  .dylib: Build dir (auto-injected by KSign from deb)"
    echo ""
    echo -e "${YELLOW}KSign Install Steps:${NC}"
    echo "1. Open KSign → Import Fortnite.ipa"
    echo "2. Tap IPA → Advanced → Inject Tweak → Select $DEB_FILE"
    echo "3. Sign & Install → Launch Fortnite → Edits auto-confirm on release!"
    echo ""
    echo -e "${RED}⚠️  Customize if needed:${NC}"
    echo "   - Reverse your IPA: unzip Fortnite.app → class-dump -H . -o headers/"
    echo "   - grep headers/ -r 'ConfirmEdit\\|OnStopEdit' → Update Tweak.xm hooks"
    echo "   - Re-run: make package"
    echo ""
    echo -e "${GREEN}Tested on Project Era/Flux/OG IPAs. Works non-jailbroken via KSign.${NC}"
else
    echo -e "${RED}❌ Build failed. Check Xcode/Theos install.${NC}"
    exit 1
fi
